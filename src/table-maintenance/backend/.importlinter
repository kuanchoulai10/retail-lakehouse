[importlinter]
root_packages =
    jobs
    shared
    base
include_external_packages = True

[importlinter:contract:domain-core-isolation]
name = Domain core (entities, value objects) does not depend on application or adapter
type = forbidden
source_modules =
    jobs.application.domain.model
forbidden_modules =
    jobs.application.port
    jobs.application.exceptions
    jobs.application.domain.service
    jobs.adapter
    shared
    fastapi
    kubernetes

[importlinter:contract:application-isolation]
name = Application does not depend on adapter
type = forbidden
source_modules =
    jobs.application
forbidden_modules =
    jobs.adapter
    shared
    fastapi
    kubernetes

[importlinter:contract:inbound-adapter-no-domain]
name = Inbound adapter does not skip layers to depend on domain
type = forbidden
source_modules =
    jobs.adapter.inbound
forbidden_modules =
    jobs.application.domain
ignore_imports =
    jobs.application.port.outbound.jobs_repo -> jobs.application.domain.model.job

[importlinter:contract:inbound-outbound-separation]
name = Inbound adapter does not depend on outbound adapter
type = forbidden
source_modules =
    jobs.adapter.inbound
forbidden_modules =
    jobs.adapter.outbound

[importlinter:contract:outbound-inbound-separation]
name = Outbound adapter does not depend on inbound adapter
type = forbidden
source_modules =
    jobs.adapter.outbound
forbidden_modules =
    jobs.adapter.inbound

[importlinter:contract:shared-leaf]
name = Shared does not depend on bounded contexts
type = forbidden
source_modules =
    shared
forbidden_modules =
    jobs
