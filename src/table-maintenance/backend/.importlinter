[importlinter]
root_packages =
    core
    api
    dependencies
    scheduler
    outbox_publisher
include_external_packages = True

[importlinter:contract:domain-core-isolation]
name = Domain core (entities, value objects) does not depend on application or adapter
type = forbidden
source_modules =
    core.application.domain.model
forbidden_modules =
    core.application.port
    core.application.exceptions
    core.application.service
    core.application.domain.service
    core.adapter
    core.configs
    fastapi
    kubernetes

[importlinter:contract:application-isolation]
name = Application does not depend on adapter
type = forbidden
source_modules =
    core.application
forbidden_modules =
    core.adapter
    core.configs
    fastapi
    kubernetes

[importlinter:contract:clean-architecture-layers]
name = Clean Architecture layer ordering
type = layers
layers =
    api.adapter.inbound.web
    core.application.event_handler
    core.application.service
    core.application.port
    core.application.domain.model

[importlinter:contract:inbound-outbound-separation]
name = Inbound adapter does not depend on outbound adapter
type = forbidden
source_modules =
    api.adapter.inbound
forbidden_modules =
    core.adapter.outbound
ignore_imports =
    dependencies.repos -> core.adapter.outbound.job.jobs_in_memory_repo
    dependencies.repos -> core.adapter.outbound.job.sql.jobs_sql_repo
    dependencies.repos -> core.adapter.outbound.job_run.job_run_in_memory_executor
    dependencies.repos -> core.adapter.outbound.job_run.job_runs_in_memory_repo
    dependencies.repos -> core.adapter.outbound.job_run.sql.job_runs_sql_repo
    dependencies.repos -> core.adapter.outbound.job_run.k8s.job_run_k8s_executor
    dependencies.repos -> core.adapter.outbound.sql.engine_factory
    dependencies.catalog -> core.adapter.outbound.catalog.iceberg_catalog_client
    dependencies.outbox -> core.adapter.outbound.sql.event_outbox_sql_repo

[importlinter:contract:outbound-inbound-separation]
name = Outbound adapter does not depend on inbound adapter
type = forbidden
source_modules =
    core.adapter.outbound
forbidden_modules =
    api.adapter.inbound

[importlinter:contract:configs-leaf]
name = Configs does not depend on bounded contexts
type = forbidden
source_modules =
    core.configs
forbidden_modules =
    core.adapter
    core.application

[importlinter:contract:base-isolation]
name = Base (DDD kernel) depends on nothing project-internal
type = forbidden
source_modules =
    core.base
forbidden_modules =
    core.application
    core.adapter
    core.configs
    api
    dependencies
    scheduler
    outbox_publisher

[importlinter:contract:domain-service-isolation]
name = Application service (use case impl) does not depend on adapter or framework
type = forbidden
source_modules =
    core.application.service
forbidden_modules =
    core.adapter
    core.configs
    api
    dependencies
    scheduler
    outbox_publisher
    fastapi
    kubernetes

[importlinter:contract:api-no-scheduler]
name = API does not depend on scheduler
type = forbidden
source_modules =
    api
forbidden_modules =
    scheduler
    outbox_publisher

[importlinter:contract:scheduler-no-api]
name = Scheduler does not depend on API
type = forbidden
source_modules =
    scheduler
forbidden_modules =
    api
    outbox_publisher
    fastapi

[importlinter:contract:outbox-publisher-no-api]
name = Outbox publisher does not depend on API
type = forbidden
source_modules =
    outbox_publisher
forbidden_modules =
    api
    fastapi

[importlinter:contract:outbox-publisher-no-scheduler]
name = Outbox publisher does not depend on scheduler
type = forbidden
source_modules =
    outbox_publisher
forbidden_modules =
    scheduler

[importlinter:contract:dependencies-no-api-adapter]
name = Dependencies does not depend on API adapter
type = forbidden
source_modules =
    dependencies
forbidden_modules =
    api.adapter

[importlinter:contract:dependencies-no-scheduler]
name = Dependencies does not depend on scheduler or outbox publisher
type = forbidden
source_modules =
    dependencies
forbidden_modules =
    scheduler
    outbox_publisher
