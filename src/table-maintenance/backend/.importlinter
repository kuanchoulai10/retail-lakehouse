[importlinter]
root_packages =
    adapter
    application
    configs
    base
    dependencies
include_external_packages = True

[importlinter:contract:domain-core-isolation]
name = Domain core (entities, value objects) does not depend on application or adapter
type = forbidden
source_modules =
    application.domain.model
forbidden_modules =
    application.port
    application.exceptions
    application.domain.service
    adapter
    configs
    fastapi
    kubernetes

[importlinter:contract:application-isolation]
name = Application does not depend on adapter
type = forbidden
source_modules =
    application
forbidden_modules =
    adapter
    configs
    fastapi
    kubernetes

[importlinter:contract:inbound-adapter-no-domain]
name = Inbound adapter does not skip layers to depend on domain
type = forbidden
source_modules =
    adapter.inbound
forbidden_modules =
    application.domain
ignore_imports =
    application.port.outbound.job.jobs_repo -> application.domain.model.job
    application.port.outbound.job_run.job_runs_repo -> application.domain.model.job_run
    application.port.outbound.job_run.job_runs_repo -> application.domain.model.job
    application.port.outbound.job_run.job_run_executor -> application.domain.model.job
    application.port.outbound.job_run.job_run_executor -> application.domain.model.job_run
    dependencies.use_cases -> application.domain.service.job.*
    dependencies.use_cases -> application.domain.service.job_run.*
    dependencies.repos -> adapter.outbound.job_run.k8s.k8s_job_runs_repo
    dependencies.repos -> adapter.outbound.job_run.k8s.k8s_job_run_executor
    dependencies.repos -> adapter.outbound.job.in_memory_jobs_repo
    dependencies.repos -> adapter.outbound.job.sql.sql_jobs_repo
    dependencies.repos -> adapter.outbound.sql.engine_factory

[importlinter:contract:inbound-outbound-separation]
name = Inbound adapter does not depend on outbound adapter
type = forbidden
source_modules =
    adapter.inbound
forbidden_modules =
    adapter.outbound
ignore_imports =
    dependencies.repos -> adapter.outbound.job_run.k8s.k8s_job_runs_repo
    dependencies.repos -> adapter.outbound.job_run.k8s.k8s_job_run_executor
    dependencies.repos -> adapter.outbound.job.in_memory_jobs_repo
    dependencies.repos -> adapter.outbound.job.sql.sql_jobs_repo
    dependencies.repos -> adapter.outbound.sql.engine_factory

[importlinter:contract:outbound-inbound-separation]
name = Outbound adapter does not depend on inbound adapter
type = forbidden
source_modules =
    adapter.outbound
forbidden_modules =
    adapter.inbound

[importlinter:contract:configs-leaf]
name = Configs does not depend on bounded contexts
type = forbidden
source_modules =
    configs
forbidden_modules =
    adapter
    application
