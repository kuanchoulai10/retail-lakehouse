[importlinter]
root_packages =
    adapter
    dependencies
    core
    api
    scheduler
include_external_packages = True

[importlinter:contract:domain-core-isolation]
name = Domain core (entities, value objects) does not depend on application or adapter
type = forbidden
source_modules =
    core.application.domain.model
forbidden_modules =
    core.application.port
    core.application.exceptions
    core.application.domain.service
    adapter
    core.configs
    fastapi
    kubernetes

[importlinter:contract:application-isolation]
name = Application does not depend on adapter
type = forbidden
source_modules =
    core.application
forbidden_modules =
    adapter
    core.configs
    fastapi
    kubernetes

[importlinter:contract:inbound-adapter-no-domain]
name = Inbound adapter does not skip layers to depend on domain
type = forbidden
source_modules =
    adapter.inbound
forbidden_modules =
    core.application.domain
ignore_imports =
    core.application.port.outbound.job.jobs_repo -> core.application.domain.model.job
    core.application.port.outbound.job_run.job_runs_repo -> core.application.domain.model.job_run
    core.application.port.outbound.job_run.job_runs_repo -> core.application.domain.model.job
    core.application.port.outbound.job_run.job_run_executor -> core.application.domain.model.job
    core.application.port.outbound.job_run.job_run_executor -> core.application.domain.model.job_run
    core.application.port.outbound.catalog.catalog_reader -> core.application.domain.model.catalog.table
    dependencies.use_cases -> core.application.domain.service.catalog.*
    dependencies.use_cases -> core.application.domain.service.job.*
    dependencies.use_cases -> core.application.domain.service.job_run.*
    dependencies.repos -> adapter.outbound.job_run.job_run_in_memory_executor
    dependencies.repos -> adapter.outbound.job_run.k8s.job_run_k8s_executor
    dependencies.repos -> adapter.outbound.job.jobs_in_memory_repo
    dependencies.repos -> adapter.outbound.job.sql.jobs_sql_repo
    dependencies.repos -> adapter.outbound.job_run.job_runs_in_memory_repo
    dependencies.repos -> adapter.outbound.job_run.sql.job_runs_sql_repo
    dependencies.repos -> adapter.outbound.sql.engine_factory
    dependencies.catalog -> adapter.outbound.catalog.iceberg_catalog_client

[importlinter:contract:inbound-outbound-separation]
name = Inbound adapter does not depend on outbound adapter
type = forbidden
source_modules =
    adapter.inbound
forbidden_modules =
    adapter.outbound
ignore_imports =
    dependencies.repos -> adapter.outbound.job_run.job_run_in_memory_executor
    dependencies.repos -> adapter.outbound.job_run.k8s.job_run_k8s_executor
    dependencies.repos -> adapter.outbound.job.jobs_in_memory_repo
    dependencies.repos -> adapter.outbound.job.sql.jobs_sql_repo
    dependencies.repos -> adapter.outbound.job_run.job_runs_in_memory_repo
    dependencies.repos -> adapter.outbound.job_run.sql.job_runs_sql_repo
    dependencies.repos -> adapter.outbound.sql.engine_factory
    dependencies.catalog -> adapter.outbound.catalog.iceberg_catalog_client

[importlinter:contract:outbound-inbound-separation]
name = Outbound adapter does not depend on inbound adapter
type = forbidden
source_modules =
    adapter.outbound
forbidden_modules =
    adapter.inbound

[importlinter:contract:configs-leaf]
name = Configs does not depend on bounded contexts
type = forbidden
source_modules =
    core.configs
forbidden_modules =
    core.adapter
    core.application
