[importlinter]
root_packages =
    core
    api
    scheduler
    outbox_publisher
include_external_packages = True

[importlinter:contract:domain-core-isolation]
name = Domain core (entities, value objects) does not depend on application or adapter
type = forbidden
source_modules =
    core.application.domain.model
forbidden_modules =
    core.application.port
    core.application.exceptions
    core.application.service
    core.application.domain.service
    core.adapter
    core.configs
    fastapi
    kubernetes

[importlinter:contract:application-isolation]
name = Application does not depend on adapter
type = forbidden
source_modules =
    core.application
forbidden_modules =
    core.adapter
    core.configs
    fastapi
    kubernetes

[importlinter:contract:inbound-adapter-no-domain]
name = Inbound adapter does not skip layers to depend on domain
type = forbidden
source_modules =
    api.adapter.inbound
forbidden_modules =
    core.application.domain
ignore_imports =
    core.application.port.outbound.job.jobs_repo -> core.application.domain.model.job
    core.application.port.outbound.job_run.job_runs_repo -> core.application.domain.model.job_run
    core.application.port.outbound.job_run.job_runs_repo -> core.application.domain.model.job
    core.application.port.outbound.job_run.job_run_executor -> core.application.domain.model.job
    core.application.port.outbound.job_run.job_run_executor -> core.application.domain.model.job_run
    core.application.port.outbound.catalog.catalog_reader -> core.application.domain.model.catalog.table
    core.application.port.outbound.event_outbox_repo -> core.application.domain.model.outbox_entry
    api.dependencies.use_cases -> core.application.service.catalog.*
    api.dependencies.use_cases -> core.application.service.job.*
    api.dependencies.use_cases -> core.application.service.job_run.*
    api.dependencies.use_cases -> core.application.event_handler.*
    api.dependencies.outbox -> core.adapter.outbound.sql.event_outbox_sql_repo
    api.dependencies.outbox -> core.application.event_handler.*
    api.dependencies.repos -> core.adapter.outbound.job_run.job_run_in_memory_executor
    api.dependencies.repos -> core.adapter.outbound.job_run.k8s.job_run_k8s_executor
    api.dependencies.repos -> core.adapter.outbound.job.jobs_in_memory_repo
    api.dependencies.repos -> core.adapter.outbound.job.sql.jobs_sql_repo
    api.dependencies.repos -> core.adapter.outbound.job_run.job_runs_in_memory_repo
    api.dependencies.repos -> core.adapter.outbound.job_run.sql.job_runs_sql_repo
    api.dependencies.repos -> core.adapter.outbound.sql.engine_factory
    api.dependencies.catalog -> core.adapter.outbound.catalog.iceberg_catalog_client

[importlinter:contract:inbound-outbound-separation]
name = Inbound adapter does not depend on outbound adapter
type = forbidden
source_modules =
    api.adapter.inbound
forbidden_modules =
    core.adapter.outbound
ignore_imports =
    api.dependencies.repos -> core.adapter.outbound.job_run.job_run_in_memory_executor
    api.dependencies.repos -> core.adapter.outbound.job_run.k8s.job_run_k8s_executor
    api.dependencies.repos -> core.adapter.outbound.job.jobs_in_memory_repo
    api.dependencies.repos -> core.adapter.outbound.job.sql.jobs_sql_repo
    api.dependencies.repos -> core.adapter.outbound.job_run.job_runs_in_memory_repo
    api.dependencies.repos -> core.adapter.outbound.job_run.sql.job_runs_sql_repo
    api.dependencies.repos -> core.adapter.outbound.sql.engine_factory
    api.dependencies.catalog -> core.adapter.outbound.catalog.iceberg_catalog_client
    api.dependencies.outbox -> core.adapter.outbound.sql.event_outbox_sql_repo

[importlinter:contract:outbound-inbound-separation]
name = Outbound adapter does not depend on inbound adapter
type = forbidden
source_modules =
    core.adapter.outbound
forbidden_modules =
    api.adapter.inbound

[importlinter:contract:configs-leaf]
name = Configs does not depend on bounded contexts
type = forbidden
source_modules =
    core.configs
forbidden_modules =
    core.adapter
    core.application

[importlinter:contract:base-isolation]
name = Base (DDD kernel) depends on nothing project-internal
type = forbidden
source_modules =
    core.base
forbidden_modules =
    core.application
    core.adapter
    core.configs
    api
    scheduler
    outbox_publisher

[importlinter:contract:domain-service-isolation]
name = Application service (use case impl) does not depend on adapter or framework
type = forbidden
source_modules =
    core.application.service
forbidden_modules =
    core.adapter
    core.configs
    api
    scheduler
    outbox_publisher
    fastapi
    kubernetes

[importlinter:contract:api-no-scheduler]
name = API does not depend on scheduler
type = forbidden
source_modules =
    api
forbidden_modules =
    scheduler
    outbox_publisher

[importlinter:contract:scheduler-no-api]
name = Scheduler does not depend on API
type = forbidden
source_modules =
    scheduler
forbidden_modules =
    api
    outbox_publisher
    fastapi

[importlinter:contract:outbox-publisher-no-api]
name = Outbox publisher does not depend on API
type = forbidden
source_modules =
    outbox_publisher
forbidden_modules =
    api
    fastapi

[importlinter:contract:outbox-publisher-no-scheduler]
name = Outbox publisher does not depend on scheduler
type = forbidden
source_modules =
    outbox_publisher
forbidden_modules =
    scheduler
